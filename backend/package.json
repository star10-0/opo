{
  "name": "fuel-system-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "healthcheck": "node -e \"const port=process.env.PORT||5000;fetch('http://localhost:'+port+'/api/health').then(r=>{if(!r.ok)process.exit(1);return r.json()}).then(()=>process.exit(0)).catch(()=>process.exit(1))\"",
    "bootstrap:dev-admin": "node scripts/bootstrap-dev-admin.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1"
  }
}
