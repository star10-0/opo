# Backend
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/fuel-station
JWT_SECRET=replace-with-strong-secret
# comma-separated origins in production, e.g. https://app.example.com,https://admin.example.com
FRONTEND_URL=http://localhost:5173
# set true in production
ENFORCE_AUTH=false

# Frontend
# in production you can keep this empty to use same-origin /api
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT_MS=10000

# security: keep demo login disabled unless explicitly needed in non-production environments
VITE_ENABLE_DEMO_LOGIN=false
